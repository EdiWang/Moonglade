@model List<Moonglade.Data.DTO.TagWithCount>

@if (Model.Any())
{
    foreach (var tag in Model)
    {
        <a asp-page="/TagList"
           asp-route-normalizedName="@tag.NormalizedName"
           rel="@tag.PostCount"
           class="d-inline-block btn btn-sm btn-accent mb-2 me-1">
            @tag.DisplayName
        </a>
    }
}