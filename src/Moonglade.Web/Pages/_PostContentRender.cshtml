@model (string Content, string ContentType)
@inject IConfiguration Configuration

@{
    var effectiveType = string.IsNullOrEmpty(Model.ContentType)
        ? Configuration.GetValue<EditorChoice>("Editor").ToString().ToLower()
        : Model.ContentType;

    var content = BlogConfig.ImageSettings.EnableCDNRedirect ? 
        Model.Content.ReplaceCDNEndpointToImgTags(BlogConfig.ImageSettings.CDNEndpoint) : 
        Model.Content;
}

@if (effectiveType == "markdown")
{
    @Html.Raw(ContentProcessor.MarkdownToContent(content, ContentProcessor.MarkdownConvertType.Html, false))
}
else
{
    @Html.Raw(content)
}