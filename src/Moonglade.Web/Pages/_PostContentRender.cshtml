@model (string Content, string ContentType)
@inject IConfiguration Configuration

@{
    var effectiveType = string.IsNullOrEmpty(Model.ContentType)
        ? Configuration.GetValue<EditorChoice>("Editor").ToString().ToLower()
        : Model.ContentType;

    var content = effectiveType == "markdown"
        ? ContentProcessor.MarkdownToContent(Model.Content, ContentProcessor.MarkdownConvertType.Html, false)
        : Model.Content;

    if (BlogConfig.ImageSettings.EnableCDNRedirect)
    {
        content = content.ReplaceCDNEndpointToImgTags(BlogConfig.ImageSettings.CDNEndpoint);
    }
}

@Html.Raw(content)
