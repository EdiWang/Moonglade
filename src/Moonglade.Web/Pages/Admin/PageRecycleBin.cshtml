@page "/admin/page/recycle-bin"
@{
    ViewBag.Title = "Pages Recycle Bin";
    ViewBag.XData = "recycleBinManager";
}

@section scripts {
    <script type="module" src="~/js/app/admin.recyclebin.mjs"></script>
}

<div id="localizedStrings" style="display:none"
     data-mode="pages"
     data-post-deleted="@SharedLocalizer["Post deleted"]"
     data-post-restored="@SharedLocalizer["Post restored"]"
     data-page-deleted="@SharedLocalizer["Page deleted"]"
     data-page-restored="@SharedLocalizer["Page restored"]"
     data-cleared="@SharedLocalizer["Cleared"]"
     data-confirm-delete="@SharedLocalizer["Are you sure you want to delete \"{0}\"?"]">
</div>

@section admintoolbar {
    <partial name="_PageManageHeader" />
}

@Html.AntiForgeryToken()

<div>
    <div x-show="isLoading"
         class="text-muted mb-3"
         :class="{ 'd-flex align-items-center': isLoading }">
        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
        <span>@SharedLocalizer["Loading..."]</span>
    </div>

    <div x-show="!isLoading && !hasItems">
        <div class="text-center">
            <h4>@SharedLocalizer["No Pages"]</h4>
            <p class="text-muted">@SharedLocalizer["no items to show"]</p>
        </div>
    </div>

    <div x-show="!isLoading && showPages" class="admin-main-entry-container">
        <template x-for="page in sortedPages" :key="page.id">
            <div :id="`page-${page.id}`" class="admin-post-entry p-3 mb-2 rounded-3 shadow-sm border">
                <div class="d-flex">
                    <div class="flex-grow-1">
                        <h6 x-text="page.title"></h6>
                        <div>
                            <i class="bi-calendar-event"></i>
                            <time :data-utc-label="page.createTimeUtc" x-text="page.createTimeUtc"></time>
                        </div>
                    </div>
                    <div>
                        <button class="btn btn-sm btn-outline-accent btn-restore"
                                x-on:click="restorePage(page.id)">
                            <i class="bi-reply-fill"></i> @SharedLocalizer["Restore"]
                        </button>
                        <button class="btn btn-outline-danger btn-sm btn-delete"
                                x-on:click="confirmDeletePage(page.id, page.title)">
                            <i class="bi-trash"></i> @SharedLocalizer["Delete"]
                        </button>
                    </div>
                </div>
            </div>
        </template>
    </div>
</div>
