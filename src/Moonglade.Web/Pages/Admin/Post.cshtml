@page "/admin/post"
@{
    ViewBag.Title = "Posts";
    ViewBag.XData = "postManager";
}

@section scripts {
    <script type="module" src="~/js/app/admin.post.mjs"></script>
}

<div id="localizedStrings" style="display:none"
     data-post-deleted="@SharedLocalizer["Post deleted"]"
     data-confirm-delete="@SharedLocalizer["Are you sure you want to delete this post?"]">
</div>

@section admintoolbar {
    <partial name="_PostManageHeader" />
    <div class="admin-toolbar pb-2 border-bottom mb-3">
        <div class="row">
            <div class="col">
                <a x-on:click="openFilter()" class="btn btn-outline-accent" role="button">
                    <i class="bi-funnel"></i>
                    @SharedLocalizer["Filter"]
                    <span x-show="activeFilterCount > 0" class="badge bg-danger ms-1" x-text="activeFilterCount"></span>
                </a>
            </div>
            <div class="col-auto">
                <div class="text-muted admin-toolbar-text">
                    <span x-text="postCount"></span> item(s)
                </div>
            </div>
        </div>
    </div>
}

@Html.AntiForgeryToken()

<div>
    <div x-show="isLoading"
         class="text-muted mb-3"
         :class="{ 'd-flex align-items-center': isLoading }">
        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
        <span>@SharedLocalizer["Loading posts..."]</span>
    </div>

    <div x-show="!isLoading && !hasPosts">
        <partial name="_NoPosts" />
    </div>

    <template x-for="post in posts" :key="post.id">
        <div :id="`post-${post.id}`" class="admin-post-entry p-3 mb-2 rounded-3 shadow-sm border">
            <div class="row">
                <div class="col">
                    <a :href="getPostUrl(post)"
                       class="d-inline-block"
                       :title="post.slug"
                       target="_blank">
                        <h6>
                            <span x-text="post.title"></span>
                            <i x-show="post.isFeatured" class="bi-star-fill text-warning"></i>
                            <span x-show="post.isOutdated" class="badge rounded-pill text-bg-secondary ms-2">Outdated</span>
                        </h6>
                    </a>
                    <div class="mb-2" x-text="post.contentAbstract"></div>
                    <div>
                        <i class="bi-calendar-event"></i>
                        <span class="text-muted me-2">
                            <time :data-utc-label="post.pubDateUtc" x-text="post.pubDateUtc"></time>
                        </span>
                    </div>
                </div>

                <div class="col-auto">
                    <a class="btn btn-outline-accent btn-sm btn-edit" 
                       :href="`/admin/post/edit/${post.id}`">
                        <i class="bi-pen"></i>
                    </a>
                    <button class="btn btn-outline-danger btn-sm btn-delete" 
                            x-on:click="deletePost(post.id)">
                        <i class="bi-trash"></i>
                    </button>
                </div>
            </div>
        </div>
    </template>

<!-- Filter Offcanvas -->
<div class="offcanvas offcanvas-end" tabindex="-1" x-ref="filterCanvas" aria-labelledby="filterCanvasLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="filterCanvasLabel">@SharedLocalizer["Filter"]</h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body d-flex flex-column p-0">
        <form x-on:submit.prevent="handleFilter()" class="d-flex flex-column h-100">
            <div class="flex-grow-1 p-3 pb-0" style="min-height: 0; overflow-y: auto;">
                <div class="mb-3">
                    <label class="form-label" for="filterTitle">@SharedLocalizer["Title"]</label>
                    <input type="text" class="form-control" id="filterTitle" x-model="titleFilter" maxlength="128" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="filterAbstract">@SharedLocalizer["Abstract"]</label>
                    <input type="text" class="form-control" id="filterAbstract" x-model="abstractFilter" maxlength="256" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="filterTag">@SharedLocalizer["Tag"]</label>
                    <input type="text" class="form-control" id="filterTag" x-model="tagFilter" maxlength="64" />
                </div>
                <hr />
                <div class="mb-3">
                    <label class="form-label" for="filterSortBy">@SharedLocalizer["Sort By"]</label>
                    <select class="form-select" id="filterSortBy" x-model="sortBy">
                        <template x-for="opt in sortByOptions" :key="opt.value">
                            <option :value="opt.value" x-text="opt.label" :selected="opt.value === sortBy"></option>
                        </template>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="filterSortOrder">@SharedLocalizer["Sort Order"]</label>
                    <select class="form-select" id="filterSortOrder" x-model="sortDescending">
                        <option value="true">@SharedLocalizer["Descending"]</option>
                        <option value="false">@SharedLocalizer["Ascending"]</option>
                    </select>
                </div>
            </div>

            <!-- Fixed Bottom Buttons -->
            <div class="border-top p-3 bg-light">
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-accent">
                        <i class="bi-funnel"></i> @SharedLocalizer["Apply Filter"]
                    </button>
                    <button type="button" class="btn btn-outline-secondary" x-on:click="clearFilter()">
                        <i class="bi-x-circle"></i> @SharedLocalizer["Clear"]
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

    <div x-show="!isLoading && hasPosts" class="d-flex justify-content-between align-items-center mt-4">
        <nav x-show="totalPages > 1" aria-label="Page navigation">
            <ul class="pagination mb-0">
                <li class="page-item" :class="{ 'disabled': currentPage === 1 }">
                    <a class="page-link" href="#" x-on:click.prevent="goToPage(1)">
                        <span aria-hidden="true">&laquo;&laquo;</span>
                    </a>
                </li>

                <li class="page-item" :class="{ 'disabled': currentPage === 1 }">
                    <a class="page-link" href="#" x-on:click.prevent="goToPage(currentPage - 1)">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>

                <template x-for="page in paginationPages" :key="page">
                    <li class="page-item" :class="{ 'active': page === currentPage }">
                        <a class="page-link" href="#" x-on:click.prevent="goToPage(page)" x-text="page"></a>
                    </li>
                </template>

                <li class="page-item" :class="{ 'disabled': currentPage === totalPages }">
                    <a class="page-link" href="#" x-on:click.prevent="goToPage(currentPage + 1)">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>

                <li class="page-item" :class="{ 'disabled': currentPage === totalPages }">
                    <a class="page-link" href="#" x-on:click.prevent="goToPage(totalPages)">
                        <span aria-hidden="true">&raquo;&raquo;</span>
                    </a>
                </li>
            </ul>
        </nav>

        <div class="d-flex align-items-center gap-2">
            <label class="form-label mb-0 text-nowrap">@SharedLocalizer["Page Size"]</label>
            <select class="form-select form-select-sm" style="width: auto;"
                    x-on:change="changePageSize($event.target.value)">
                <template x-for="size in pageSizeOptions" :key="size">
                    <option :value="size" x-text="size" :selected="size === pageSize"></option>
                </template>
            </select>
        </div>
    </div>
</div>